# name: test/sql/pac_counters.test
# description: Test pac_* aggregate functions that return LIST<DOUBLE> for categorical queries
# group: [sql]

require pac

statement ok
PRAGMA clear_pac_metadata;

statement ok
PRAGMA enable_verification

# Set deterministic seed for reproducibility
statement ok
SET pac_seed = 42

statement ok
SET pac_hash_repair = true

statement ok
SET threads = 1

statement ok
SET pac_mi = 0

# Create simple test data - 10 rows for easy verification
statement ok
CREATE TABLE test_data AS
SELECT i AS rowid, i % 3 AS group_id, i * 10 AS value
FROM range(10) t(i)

# ============================================================================
# PAC_COUNT tests
# ============================================================================

# Basic test - returns LIST<FLOAT>
query I
SELECT typeof(pac_count(pac_hash(hash(rowid)::UBIGINT))) FROM test_data
----
FLOAT[]

# Returns exactly 64 elements
query I
SELECT length(pac_count(pac_hash(hash(rowid)::UBIGINT))) FROM test_data
----
64

# Show first 5 counter values (doubled to compensate for 50% sampling)
query IIIII
SELECT
    pac_count(pac_hash(hash(rowid)::UBIGINT))[1]::INTEGER,
    pac_count(pac_hash(hash(rowid)::UBIGINT))[2]::INTEGER,
    pac_count(pac_hash(hash(rowid)::UBIGINT))[3]::INTEGER,
    pac_count(pac_hash(hash(rowid)::UBIGINT))[4]::INTEGER,
    pac_count(pac_hash(hash(rowid)::UBIGINT))[5]::INTEGER
FROM test_data
----
10	12	16	10	10

# Grouped pac_count - show first counter per group (NULL where key_hash bit 0 is not set)
query II
SELECT group_id, pac_count(pac_hash(hash(rowid)::UBIGINT))[1]::INTEGER AS counter1
FROM test_data
GROUP BY group_id
ORDER BY group_id
----
0	4
1	2
2	4

# With column parameter (doubled)
query I
SELECT pac_count(pac_hash(hash(rowid)::UBIGINT), value)[1]::INTEGER FROM test_data
----
10

# ============================================================================
# PAC_SUM tests
# ============================================================================

# Basic test - returns LIST<DOUBLE>
query I
SELECT typeof(pac_sum(pac_hash(hash(rowid)::UBIGINT), value)) FROM test_data
----
FLOAT[]

# Returns exactly 64 elements
query I
SELECT length(pac_sum(pac_hash(hash(rowid)::UBIGINT), value)) FROM test_data
----
64

# Show first 5 sum counter values (doubled to compensate for 50% sampling)
query IIIII
SELECT
    pac_sum(pac_hash(hash(rowid)::UBIGINT), value)[1]::INTEGER,
    pac_sum(pac_hash(hash(rowid)::UBIGINT), value)[2]::INTEGER,
    pac_sum(pac_hash(hash(rowid)::UBIGINT), value)[3]::INTEGER,
    pac_sum(pac_hash(hash(rowid)::UBIGINT), value)[4]::INTEGER,
    pac_sum(pac_hash(hash(rowid)::UBIGINT), value)[5]::INTEGER
FROM test_data
----
400	580	680	580	520

# Grouped pac_sum - show first counter per group (NULL where key_hash bit 0 is not set)
query II
SELECT group_id, pac_sum(pac_hash(hash(rowid)::UBIGINT), value)[1]::INTEGER AS sum1
FROM test_data
GROUP BY group_id
ORDER BY group_id
----
0	60
1	140
2	200

# ============================================================================
# NOTE: pac_avg has been removed. avg() is decomposed into
# pac_sum(hash,col) + pac_count(hash,col) + pac_noised_div by the bitslice compiler.
# The categorical rewriter swaps pac_noised_div → pac_div for the filter/join path.
# ============================================================================

# ============================================================================
# PAC_MIN tests
# ============================================================================

# Basic test - returns LIST<DOUBLE>
query I
SELECT typeof(pac_min(pac_hash(hash(rowid)::UBIGINT), value)) FROM test_data
----
FLOAT[]

# Returns exactly 64 elements
query I
SELECT length(pac_min(pac_hash(hash(rowid)::UBIGINT), value)) FROM test_data
----
64

# Show first 5 min counter values (no scaling for min/max)
query IIIII
SELECT
    pac_min(pac_hash(hash(rowid)::UBIGINT), value)[1]::INTEGER,
    pac_min(pac_hash(hash(rowid)::UBIGINT), value)[2]::INTEGER,
    pac_min(pac_hash(hash(rowid)::UBIGINT), value)[3]::INTEGER,
    pac_min(pac_hash(hash(rowid)::UBIGINT), value)[4]::INTEGER,
    pac_min(pac_hash(hash(rowid)::UBIGINT), value)[5]::INTEGER
FROM test_data
----
0	10	0	20	10

# Grouped pac_min - show first counter per group
query II
SELECT group_id, pac_min(pac_hash(hash(rowid)::UBIGINT), value)[1]::INTEGER AS min1
FROM test_data
GROUP BY group_id
ORDER BY group_id
----
0	0
1	70
2	20

# ============================================================================
# PAC_MAX tests
# ============================================================================

# Basic test - returns LIST<DOUBLE>
query I
SELECT typeof(pac_max(pac_hash(hash(rowid)::UBIGINT), value)) FROM test_data
----
FLOAT[]

# Returns exactly 64 elements
query I
SELECT length(pac_max(pac_hash(hash(rowid)::UBIGINT), value)) FROM test_data
----
64

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DROP TABLE test_data
